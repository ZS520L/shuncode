{
	"name": "shuncode",
	"displayName": "ShunCode AI",
	"description": "AI-powered code assistant for STP.",
	"version": "0.6.0",
	"icon": "assets/icons/icon.png",
	"enabledApiProposals": [
		"editorInsets"
	],
	"engines": {
		"vscode": "^1.84.0"
	},
	"author": {
		"name": "SHUNCODE"
	},
	"license": "Apache-2.0",
	"publisher": "shuncode",
	"repository": {
		"type": "git",
		"url": "#"
	},
	"homepage": "#",
	"categories": [
		"AI",
		"Chat",
		"Programming Languages",
		"Education",
		"Snippets",
		"Testing"
	],
	"keywords": [
		"shuncode",
		"claude",
		"dev",
		"mcp",
		"openrouter",
		"coding",
		"agent",
		"autonomous",
		"chatgpt",
		"sonnet",
		"ai",
		"llama"
	],
	"activationEvents": [
		"onLanguage",
		"onStartupFinished",
		"workspaceContains:evals.env"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"configurationDefaults": {
			"typescript.validate.enable": false,
			"javascript.validate.enable": false,
			"js/ts.validate.enabled": false,
			"css.validate": false,
			"scss.validate": false,
			"less.validate": false,
			"html.validate.scripts": false,
			"html.validate.styles": false,
			"json.validate.enable": false,
			"php.validate.enable": false
		},
		"icons": {
			"shuncode-icon": {
				"description": "shuncode",
				"default": {
					"fontPath": "assets/icons/shuncode-bot.woff",
					"fontCharacter": "\\e900"
				}
			}
		},
		"walkthroughs": [
			{
				"id": "ShunCodeWalkthrough",
				"title": "Meet ShunCode, your new coding partner",
				"description": "ShunCode codes like a developer because it thinks like one. Here are 5 ways to put it to work:",
				"steps": [
					{
						"id": "welcome",
						"title": "Start with a Goal, Not Just a Prompt",
						"description": "Tell ShunCode what you want to achieve. It plans, asks, and then codes, like a true partner.",
						"media": {
							"markdown": "walkthrough/step1.md"
						}
					},
					{
						"id": "learn",
						"title": "Let ShunCode Learn Your Codebase",
						"description": "Point ShunCode to your project. It builds understanding to make smart, context-aware changes.",
						"media": {
							"markdown": "walkthrough/step2.md"
						}
					},
					{
						"id": "advanced-features",
						"title": "Always Use the Best AI Models",
						"description": "ShunCode empowers you with State-of-the-Art AI, connecting to top models (Anthropic, Gemini, OpenAI & more).",
						"media": {
							"markdown": "walkthrough/step3.md"
						}
					},
					{
						"id": "mcp",
						"title": "Extend with Powerful Tools (MCP)",
						"description": "Connect to databases, APIs, or discover new capabilities in the MCP Marketplace.",
						"media": {
							"markdown": "walkthrough/step4.md"
						}
					},
					{
						"id": "getting-started",
						"title": "You're Always in Control",
						"description": "Review ShunCode's plans and diffs. Approve changes before they happen. No surprises.",
						"media": {
							"markdown": "walkthrough/step5.md"
						},
						"content": {
							"path": "walkthrough/step5.md"
						}
					}
				]
			}
		],
		"views": {
			"workbench.panel.chat": [
				{
					"type": "webview",
					"id": "shuncode.SidebarProvider",
					"name": "ShunCode",
					"when": "true"
				}
			]
		},
		"commands": [
			{
				"command": "shuncode.plusButtonClicked",
				"title": "New Task",
				"icon": "$(add)"
			},
			{
				"command": "shuncode.mcpButtonClicked",
				"title": "MCP Servers",
				"icon": "$(server)"
			},
			{
				"command": "shuncode.historyButtonClicked",
				"title": "History",
				"icon": "$(history)"
			},
			{
				"command": "shuncode.settingsButtonClicked",
				"title": "Settings",
				"icon": "$(settings-gear)"
			},
			{
				"command": "shuncode.indexing.reindex",
				"title": "ShunCode: Переиндексировать кодовую базу",
				"icon": "$(refresh)"
			},
			{
				"command": "shuncode.indexing.clear",
				"title": "ShunCode: Очистить индекс кодовой базы",
				"icon": "$(trash)"
			},
			{
				"command": "shuncode.indexing.pause",
				"title": "ShunCode: Приостановить индексацию",
				"icon": "$(debug-pause)"
			},
			{
				"command": "shuncode.indexing.resume",
				"title": "ShunCode: Продолжить индексацию",
				"icon": "$(play)"
			},
			{
				"command": "shuncode.dev.createTestTasks",
				"title": "Create Test Tasks",
				"category": "ShunCode",
				"when": "shuncode.isDevMode"
			},
			{
				"command": "shuncode.dev.expireMcpOAuthTokens",
				"title": "Expire MCP OAuth Tokens (for testing)",
				"category": "ShunCode",
				"when": "shuncode.isDevMode"
			},
			{
				"command": "shuncode.addToChat",
				"title": "Добавить в ShunCode",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.addTerminalOutputToChat",
				"title": "Добавить в ShunCode",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.focusChatInput",
				"title": "Jump to Chat Input",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.generateGitCommitMessage",
				"title": "Сгенерировать коммит с ShunCode",
				"category": "ShunCode",
				"icon": "$(shuncode-icon)"
			},
			{
				"command": "shuncode.abortGitCommitMessage",
				"title": "Generate Commit Message with ShunCode - Stop",
				"category": "ShunCode",
				"icon": "$(debug-stop)"
			},
			{
				"command": "shuncode.explainCode",
				"title": "Объяснить с помощью ShunCode",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.improveCode",
				"title": "Улучшить с помощью ShunCode",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.jupyterGenerateCell",
				"title": "Generate Jupyter Cell with ShunCode",
				"category": "ShunCode",
				"icon": "$(sparkle)"
			},
			{
				"command": "shuncode.jupyterExplainCell",
				"title": "Explain Jupyter Cell with ShunCode",
				"category": "ShunCode",
				"icon": "$(question)"
			},
			{
				"command": "shuncode.jupyterImproveCell",
				"title": "Improve Jupyter Cell with ShunCode",
				"category": "ShunCode",
				"icon": "$(lightbulb)"
			},
			{
				"command": "shuncode.openWalkthrough",
				"title": "Open Walkthrough",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.reconstructTaskHistory",
				"title": "Reconstruct Task History",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.clearAllDiffs",
				"title": "Очистить все ожидающие диффы (legacy)",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.diff.accept",
				"title": "Принять изменение",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.diff.reject",
				"title": "Отклонить изменение",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.pendingChanges.openFile",
				"title": "Открыть файл",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.pendingChanges.acceptAll",
				"title": "Принять все изменения",
				"icon": "$(check-all)",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.pendingChanges.rejectAll",
				"title": "Отклонить все изменения",
				"icon": "$(close-all)",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.pendingChanges.acceptFile",
				"title": "Принять изменения в файле",
				"icon": "$(check)",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.pendingChanges.rejectFile",
				"title": "Отклонить изменения в файле",
				"icon": "$(close)",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.pendingChanges.refresh",
				"title": "Обновить",
				"icon": "$(refresh)",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.diff.acceptAllInFile",
				"title": "Принять все изменения в файле",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.diff.rejectAllInFile",
				"title": "Отклонить все изменения в файле",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.diff.clearAll",
				"title": "Очистить все ожидающие диффы",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.diff.nextHunk",
				"title": "Следующее изменение",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.diff.prevHunk",
				"title": "Предыдущее изменение",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.diff.acceptCurrent",
				"title": "Принять текущее изменение",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.diff.rejectCurrent",
				"title": "Отклонить текущее изменение",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.inlineEdit",
				"title": "ShunCode: Inline Edit",
				"category": "ShunCode"
			},
			{
				"command": "shuncode.reviewComment.reply",
				"title": "Reply",
				"category": "ShunCode",
				"enablement": "!commentIsEmpty"
			},
			{
				"command": "shuncode.reviewComment.addToChat",
				"title": "Добавить в чат ShunCode",
				"category": "ShunCode",
				"icon": "$(link-external)"
			}
		],
		"keybindings": [
			{
				"command": "editor.action.submitComment",
				"key": "enter",
				"when": "commentEditorFocused && commentController == shuncode-ai-review && !commentIsEmpty"
			},
			{
				"command": "shuncode.addToChat",
				"key": "cmd+'",
				"mac": "cmd+'",
				"win": "ctrl+'",
				"linux": "ctrl+'",
				"when": "editorHasSelection"
			},
			{
				"command": "shuncode.generateGitCommitMessage",
				"when": "config.git.enabled && scmProvider == git"
			},
			{
				"command": "shuncode.focusChatInput",
				"key": "cmd+'",
				"mac": "cmd+'",
				"win": "ctrl+'",
				"linux": "ctrl+'",
				"when": "!editorHasSelection"
			},
			{
				"command": "shuncode.diff.nextHunk",
				"key": "alt+]",
				"mac": "alt+]",
				"when": "editorTextFocus && shuncode.hasPendingHunks"
			},
			{
				"command": "shuncode.diff.prevHunk",
				"key": "alt+[",
				"mac": "alt+[",
				"when": "editorTextFocus && shuncode.hasPendingHunks"
			},
			{
				"command": "shuncode.diff.acceptCurrent",
				"key": "ctrl+shift+y",
				"mac": "cmd+shift+y",
				"when": "editorTextFocus && shuncode.hasPendingHunks"
			},
			{
				"command": "shuncode.diff.rejectCurrent",
				"key": "ctrl+shift+n",
				"mac": "cmd+shift+n",
				"when": "editorTextFocus && shuncode.hasPendingHunks"
			},
			{
				"command": "shuncode.inlineEdit",
				"key": "ctrl+shift+k",
				"mac": "cmd+shift+k",
				"when": "editorTextFocus && editorHasSelection"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "shuncode.plusButtonClicked",
					"group": "navigation@1",
					"when": "view == shuncode.SidebarProvider"
				},
				{
					"command": "shuncode.mcpButtonClicked",
					"group": "navigation@2",
					"when": "view == shuncode.SidebarProvider"
				},
				{
					"command": "shuncode.historyButtonClicked",
					"group": "navigation@3",
					"when": "view == shuncode.SidebarProvider"
				},
				{
					"command": "shuncode.settingsButtonClicked",
					"group": "navigation@6",
					"when": "view == shuncode.SidebarProvider"
				},
				{
					"command": "shuncode.pendingChanges.acceptAll",
					"group": "navigation@1",
					"when": "view == shuncodePendingChanges"
				},
				{
					"command": "shuncode.pendingChanges.rejectAll",
					"group": "navigation@2",
					"when": "view == shuncodePendingChanges"
				},
				{
					"command": "shuncode.pendingChanges.refresh",
					"group": "navigation@3",
					"when": "view == shuncodePendingChanges"
				}
			],
			"view/item/context": [
				{
					"command": "shuncode.pendingChanges.acceptFile",
					"when": "view == shuncodePendingChanges && viewItem == pendingChangeFile",
					"group": "inline@1"
				},
				{
					"command": "shuncode.pendingChanges.rejectFile",
					"when": "view == shuncodePendingChanges && viewItem == pendingChangeFile",
					"group": "inline@2"
				}
			],
			"editor/context": [
				{
					"command": "shuncode.addToChat",
					"group": "navigation",
					"when": "editorHasSelection"
				}
			],
			"terminal/context": [
				{
					"command": "shuncode.addTerminalOutputToChat",
					"group": "navigation"
				}
			],
			"scm/title": [
				{
					"command": "shuncode.generateGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && !shuncode.isGeneratingCommit"
				},
				{
					"command": "shuncode.abortGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && shuncode.isGeneratingCommit"
				}
			],
			"notebook/toolbar": [
				{
					"command": "shuncode.jupyterGenerateCell",
					"group": "navigation/add@1",
					"when": "notebookType == 'jupyter-notebook'"
				}
			],
			"notebook/cell/title": [
				{
					"command": "shuncode.jupyterExplainCell",
					"group": "inline@1",
					"when": "notebookType == 'jupyter-notebook'"
				},
				{
					"command": "shuncode.jupyterImproveCell",
					"group": "inline@2",
					"when": "notebookType == 'jupyter-notebook'"
				}
			],
			"commandPalette": [
				{
					"command": "shuncode.generateGitCommitMessage",
					"when": "config.git.enabled && !shuncode.isGeneratingCommit"
				},
				{
					"command": "shuncode.abortGitCommitMessage",
					"when": "config.git.enabled && shuncode.isGeneratingCommit"
				},
				{
					"command": "shuncode.reviewComment.reply",
					"when": "false"
				}
			],
			"comments/commentThread/context": [
				{
					"command": "shuncode.reviewComment.reply",
					"group": "inline",
					"when": "commentController == shuncode-ai-review"
				}
			],
			"comments/commentThread/title": [
				{
					"command": "shuncode.reviewComment.addToChat",
					"group": "inline",
					"when": "commentController == shuncode-ai-review"
				}
			]
		},
		"configuration": {
			"title": "ShunCode AI",
			"properties": {
				"shuncode.validateSyntaxBeforeApply": {
					"type": "boolean",
					"default": false,
					"description": "Проверять синтаксис кода перед применением изменений (использует Tree-sitter)"
				},
				"shuncode.blockOnSyntaxErrors": {
					"type": "boolean",
					"default": false,
					"description": "Блокировать применение изменений если они добавляют синтаксические ошибки (рекомендуется)"
				},
				"shuncode.useSimplifiedEditTools": {
					"type": "boolean",
					"default": false,
					"description": "Использовать упрощённые инструменты редактирования (deleteBlock, replaceText). Управляется через 'Облегчённый режим' в настройках провайдера."
				},
				"shuncode.blockLargeFileRewrites": {
					"type": "boolean",
					"default": false,
					"description": "Блокировать write_to_file если изменяется слишком большая часть файла. По умолчанию выключено — модель сама решает."
				},
				"shuncode.largeRewriteThreshold": {
					"type": "number",
					"default": 0.6,
					"minimum": 0.1,
					"maximum": 1,
					"description": "Порог (0.1–1.0) для blockLargeFileRewrites. Например 0.6 = блокировка при изменении >60% строк файла."
				},
				"shuncode.indexing.mode": {
					"type": "string",
					"enum": [
						"off",
						"local",
						"remote"
					],
					"default": "local",
					"enumDescriptions": [
						"Индексация выключена",
						"Локальная индексация (встроенная модель, без интернета)",
						"Удалённый API (OpenAI-compatible endpoint)"
					],
					"description": "Режим индексации кодовой базы для семантического поиска"
				},
				"shuncode.indexing.localModel": {
					"type": "string",
					"enum": [
						"mini",
						"base",
						"large"
					],
					"default": "mini",
					"enumDescriptions": [
						"Быстрая (~23 МБ) — базовая мультиязычная поддержка",
						"Сбалансированная (~278 МБ) — хороший мультиязычный поиск, скачивается при первом использовании",
						"Качественная (~562 МБ) — лучший мультиязычный поиск, скачивается при первом использовании"
					],
					"description": "Локальная модель эмбеддингов для индексации (mini — быстрая, base/large — лучше качество, но больше размер)"
				},
				"shuncode.indexing.remoteApiUrl": {
					"type": "string",
					"default": "",
					"description": "URL удалённого API для эмбеддингов (формат OpenAI: https://api.openai.com/v1/embeddings)"
				},
				"shuncode.indexing.remoteApiKey": {
					"type": "string",
					"default": "",
					"description": "API ключ для удалённого сервиса эмбеддингов"
				},
				"shuncode.indexing.remoteModel": {
					"type": "string",
					"default": "text-embedding-3-small",
					"description": "Название модели эмбеддингов на удалённом API"
				},
				"shuncode.indexing.maxFileSize": {
					"type": "number",
					"default": 102400,
					"description": "Максимальный размер файла для индексации (в байтах, по умолчанию 100KB)"
				},
				"shuncode.indexing.ignoredPatterns": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [
						"node_modules",
						".git",
						"dist",
						"build",
						"out",
						".next",
						"__pycache__",
						".venv",
						"coverage",
						".cache",
						"*.min.js",
						"*.min.css",
						"*.map",
						"*.lock",
						"package-lock.json",
						"yarn.lock",
						"pnpm-lock.yaml"
					],
					"description": "Паттерны игнорирования при индексации (glob)"
				},
				"shuncode.fastContext.enabled": {
					"type": "boolean",
					"default": false,
					"description": "Enable Fast Context sub-agent for agentic code search"
				},
				"shuncode.fastContext.apiUrl": {
					"type": "string",
					"default": "",
					"description": "OpenAI-compatible chat/completions endpoint URL for the Fast Context sub-agent"
				},
				"shuncode.fastContext.apiKey": {
					"type": "string",
					"default": "",
					"description": "API key for the Fast Context LLM endpoint"
				},
				"shuncode.fastContext.modelId": {
					"type": "string",
					"default": "",
					"description": "Model ID for the Fast Context sub-agent (e.g. gpt-4o-mini, gemini-2.0-flash)"
				},
				"shuncode.fastContext.maxTurns": {
					"type": "number",
					"default": 4,
					"minimum": 1,
					"maximum": 8,
					"description": "Maximum serial turns for the search sub-agent (1-8)"
				},
				"shuncode.fastContext.maxParallelCalls": {
					"type": "number",
					"default": 8,
					"minimum": 1,
					"maximum": 16,
					"description": "Maximum parallel tool calls per turn (1-16)"
				},
				"shuncode.fastContext.timeoutSeconds": {
					"type": "number",
					"default": 30,
					"minimum": 5,
					"maximum": 120,
					"description": "Timeout in seconds for the entire search operation"
				},
				"shuncode.fastContext.systemPrompt": {
					"type": "string",
					"default": "",
					"description": "Custom system prompt for the Fast Context sub-agent (leave empty for default)"
				},
				"shuncode.fastContext.excludePatterns": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [
						"node_modules",
						".git",
						"dist",
						"build",
						"out",
						".next",
						"__pycache__",
						".venv",
						"*.min.js",
						"*.min.css",
						"*.map",
						"*.lock"
					],
					"description": "File/directory patterns to exclude from Fast Context search"
				},
				"shuncode.fastContext.maxReadFileSize": {
					"type": "number",
					"default": 65536,
					"description": "Maximum file size in bytes for read_file tool (default 64KB)"
				},
				"shuncode.fastContext.showProgress": {
					"type": "boolean",
					"default": true,
					"description": "Show search progress in the UI"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "npm run check-types && npm run lint && node esbuild.mjs",
		"compile-standalone": "npm run check-types && npm run lint && node esbuild.mjs --standalone",
		"compile-standalone-npm": "npm run protos && npm run protos-go && npm run check-types && npm run lint && node esbuild.mjs --standalone",
		"compile-cli": "scripts/build-cli.sh",
		"compile-cli-all-platforms": "scripts/build-cli-all-platforms.sh",
		"compile-cli-man-page": "pandoc cli/man/shuncode.1.md -s -t man -o cli/man/shuncode.1",
		"test:install": "bash scripts/test-install.sh",
		"dev:cli:watch": "node scripts/dev-cli-watch.mjs",
		"postcompile-standalone": "node scripts/package-standalone.mjs",
		"postcompile-standalone-npm": "node scripts/package-npm.mjs",
		"dev": "npm run protos && npm run watch",
		"watch": "npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.mjs --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "npm run check-types && npm run build:webview && npm run lint && node esbuild.mjs --production",
		"protos": "node scripts/build-proto.mjs",
		"protos-go": "node scripts/build-go-proto.mjs",
		"protos-python": "node scripts/build-python-proto.mjs",
		"cli-providers": "node scripts/cli-providers.mjs",
		"download-ripgrep": "node scripts/download-ripgrep.mjs",
		"postprotos": "biome format src/shared/proto src/core/controller src/hosts/ webview-ui/src/services src/generated --write --no-errors-on-unmatched",
		"clean:build": "rimraf dist dist-standalone webview-ui/build src/generated out/",
		"clean:deps": "rimraf node_modules webview-ui/node_modules",
		"clean:all": "npm run clean:build && npm run clean:deps",
		"compile-tests": "node ./scripts/build-tests.js",
		"watch-tests": "tsc -p . -w --outDir out",
		"check-types": "npm run protos && npx tsc --noEmit && cd webview-ui && npx tsc --noEmit",
		"lint": "biome lint --no-errors-on-unmatched --files-ignore-unknown=true --diagnostic-level=error && npm run lint:proto",
		"lint:proto": "bash ./scripts/proto-lint.sh",
		"format": "biome format --changed --no-errors-on-unmatched --files-ignore-unknown=true --diagnostic-level=error",
		"format:fix": "biome check --changed --no-errors-on-unmatched --files-ignore-unknown=true --write",
		"fix:all": "biome check --no-errors-on-unmatched --files-ignore-unknown=true --write --diagnostic-level=error --unsafe",
		"ci:check-all": "npm-run-all -p check-types lint format",
		"ci:build": "npm run protos && npm run build:webview && node esbuild.mjs && npm run compile-tests",
		"pretest": "npm run compile && npm run compile-tests && npm run compile-standalone && npm run lint",
		"test": "npm-run-all test:unit test:integration",
		"test:integration": "vscode-test",
		"test:unit": "cross-env TS_NODE_PROJECT=./tsconfig.unit-test.json mocha",
		"test:coverage": "vscode-test --coverage",
		"test:sca-server": "npx tsx watch scripts/test-standalone-core-api-server.ts",
		"test:tp-orchestrator": "npx tsx scripts/testing-platform-orchestrator.ts",
		"e2e": "playwright test -c playwright.config.ts",
		"test:e2e:build": "vsce package --allow-package-secrets sendgrid --out dist/e2e.vsix",
		"test:e2e": "playwright install && npm run test:e2e:build && node src/test/e2e/utils/build.mjs && playwright test",
		"test:e2e:optimal": "npm run test:e2e:build && node src/test/e2e/utils/build.mjs && playwright test",
		"test:e2e:ui": "npx tsx scripts/interactive-playwright.ts",
		"install:all": "npm install && cd webview-ui && npm install",
		"dev:webview": "cd webview-ui && npm run dev",
		"build:webview": "cd webview-ui && npm run build",
		"test:webview": "cd webview-ui && npm run test",
		"publish:marketplace": "vsce publish --allow-package-secrets sendgrid && ovsx publish",
		"publish:marketplace:prerelease": "vsce publish --allow-package-secrets sendgrid --pre-release && ovsx publish --pre-release",
		"publish:marketplace:nightly": "node ./scripts/publish-nightly.mjs",
		"report-issue": "node scripts/report-issue.js",
		"storybook": "cd webview-ui && npm run storybook"
	},
	"lint-staged": {
		"src/shared/storage/state-keys.ts": [
			"node scripts/generate-state-proto.mjs",
			"git add proto/shuncode/state.proto"
		],
		"*": [
			"biome check --write --staged --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
